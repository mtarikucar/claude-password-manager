{
  "manifest_version": 3,
  "name": "Claude Password Manager",
  "version": "1.0.0",
  "description": "Auto-save and autofill logins to your local, OS-protected Claude Password Manager vault.",
  "key": "",
  "permissions": ["nativeMessaging", "activeTab", "tabs", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": { "default_popup": "popup.html", "default_title": "Claude Password Manager" }
}
